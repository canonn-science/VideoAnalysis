<UserControl x:Class="VideoAnalysis.App.Views.SlitScanControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CanonnSurface2Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CanonnBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Width" Value="310"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <!-- Same card look, but stretches to fill its Grid column instead of a fixed width - used
             by the parameter cards now that they sit in a predictable 2-column Grid rather than a
             width-dependent WrapPanel. -->
        <Style x:Key="GridCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Width" Value="NaN"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style x:Key="CardHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource CanonnAccentBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource CanonnTextBrightBrush}"/>
        </Style>
        <!-- Deliberately plain (no bold/accent trigger) so switching modes doesn't visually "pop"
             the way the collapsible checkboxes elsewhere do - it's just a set of three peer options. -->
        <Style x:Key="ModeRadioStyle" TargetType="RadioButton">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource CanonnTextBrightBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" Background="{StaticResource CanonnSurfaceBrush}"
                                BorderBrush="{StaticResource CanonnBorderBrush}" BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource CanonnAccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <SolidColorBrush x:Key="ValidationErrorBrush" Color="#FF6B6B"/>
    </UserControl.Resources>

    <StackPanel>

        <!-- Preview: a single cached frame with a vector overlay of the current slit geometry -
             not a rendered result, just a guide so angle/position/rotation settings can be judged
             without running the full render. -->
        <Border Style="{StaticResource GridCardStyle}">
            <StackPanel>
                <TextBlock Text="Preview" Style="{StaticResource CardHeaderStyle}"/>
                <Grid x:Name="PreviewContainer" Height="240" ClipToBounds="True" SizeChanged="PreviewContainer_SizeChanged">
                    <Border Background="{StaticResource CanonnSurfaceBrush}" BorderBrush="{StaticResource CanonnBorderBrush}" BorderThickness="1"/>
                    <Image x:Name="PreviewImage" Stretch="Uniform"/>
                    <Canvas x:Name="PreviewOverlayCanvas" ClipToBounds="True"/>
                    <TextBlock x:Name="PreviewPlaceholderText" Text="Upload a video to see a live geometry preview"
                               Foreground="{StaticResource CanonnTextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="24"/>
                </Grid>
                <TextBlock Text="Guide only - shows where the slit samples from (or the rotation orbit) on a single cached frame. Not a rendered preview of the output."
                           FontSize="11" Foreground="{StaticResource CanonnTextMutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Preset: sets a full parameter bundle (mode, angle, width/speed ratio, blend, easing,
             etc.) across every card below for a well-known slit-scan result, unlike "Motion
             direction" above (which only ever touches angle + sampling order). Every field stays
             editable afterward - it's a starting point, not a locked mode. -->
        <Border Style="{StaticResource GridCardStyle}">
            <StackPanel>
                <TextBlock Text="Preset" Style="{StaticResource CardHeaderStyle}"/>
                <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4"
                           ToolTip="Populates every relevant control (mode, angle, width/speed ratio, blend, easing, and more) for a well-known slit-scan result. Everything stays editable afterward - it's a starting point, not a locked mode. Choosing a preset resets every other control to its default first, then applies the preset's own values."
                           Text="Result preset"/>
                <ComboBox x:Name="PresetCombo" SelectionChanged="PresetCombo_SelectionChanged" Margin="0,0,0,4">
                    <ComboBoxItem Content="None" Tag="None" IsSelected="True"/>
                    <ComboBoxItem Content="— Documentary / measurement —" IsEnabled="False" FontStyle="Italic"/>
                    <ComboBoxItem Content="Panorama (Push-Broom)" Tag="Panorama"/>
                    <ComboBoxItem Content="Movie Barcode" Tag="MovieBarcode"/>
                    <ComboBoxItem Content="Photo-Finish" Tag="PhotoFinish"/>
                    <ComboBoxItem Content="Star Trail Vortex" Tag="StarTrailVortex"/>
                    <ComboBoxItem Content="— Artistic —" IsEnabled="False" FontStyle="Italic"/>
                    <ComboBoxItem Content="Fast Spiral" Tag="FastSpiral"/>
                    <ComboBoxItem Content="Slow Vortex" Tag="SlowVortex"/>
                    <ComboBoxItem Content="Slit-Scan Portrait Warp" Tag="PortraitWarp"/>
                    <ComboBoxItem Content="Ghost Trail" Tag="GhostTrail"/>
                    <ComboBoxItem Content="Glitch / Rolling-Shutter" Tag="Glitch"/>
                    <ComboBoxItem Content="Vertical Panorama" Tag="VerticalPanorama"/>
                </ComboBox>
                <TextBlock x:Name="PresetHintText" Foreground="{StaticResource CanonnTextMutedBrush}" FontSize="11"
                           TextWrapping="Wrap" Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- Parameter cards, in a fixed 2-column Grid rather than a width-driven WrapPanel, so the
             layout stays predictable (Geometry/Motion, Sampling/Compositing, Output) instead of
             reflowing unpredictably at in-between window widths. -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Geometry -->
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource GridCardStyle}">
                <StackPanel>
                    <TextBlock Text="Geometry" Style="{StaticResource CardHeaderStyle}"/>

                    <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4"
                               ToolTip="Convenience preset - sets Slit angle above and Sampling order (in the Sampling card) for a guessed direction of subject motion. Not a separate algorithm input; adjust angle/sampling order directly for anything else."
                               Text="Motion direction (optional preset)"/>
                    <ComboBox x:Name="MotionDirectionCombo" SelectionChanged="MotionDirectionCombo_SelectionChanged" Margin="0,0,0,4">
                        <ComboBoxItem Content="None" Tag="None" IsSelected="True"/>
                        <ComboBoxItem Content="Left to right" Tag="LeftToRight"/>
                        <ComboBoxItem Content="Right to left" Tag="RightToLeft"/>
                        <ComboBoxItem Content="Top to bottom" Tag="TopToBottom"/>
                        <ComboBoxItem Content="Bottom to top" Tag="BottomToTop"/>
                    </ComboBox>
                    <TextBlock x:Name="MotionDirectionHintText" Foreground="{StaticResource CanonnTextMutedBrush}" FontSize="11"
                               TextWrapping="Wrap" Visibility="Collapsed" Margin="0,0,0,14"/>

                    <TextBlock Style="{StaticResource FieldLabelStyle}"
                               ToolTip="The line the slit samples from each frame. 90° = vertical slit (left-right scan); 0° = horizontal slit (top-bottom scan). Not used in Rotational mode, which derives the angle from the orbit instead.">
                        <Run Text="Slit angle:"/> <Run x:Name="SlitAngleValueText" Text="90°"/>
                    </TextBlock>
                    <Slider x:Name="SlitAngleSlider" Minimum="0" Maximum="180" Value="90" TickFrequency="15" IsSnapToTickEnabled="False"
                            ValueChanged="SlitAngleSlider_ValueChanged" Margin="0,2,0,4"/>
                    <TextBlock x:Name="SlitAngleDisabledHint" Foreground="{StaticResource CanonnTextMutedBrush}" FontSize="11"
                               Text="Set by rotation in Rotational mode" Visibility="Collapsed" Margin="0,0,0,8"/>

                    <TextBlock x:Name="SlitPositionLabel" Style="{StaticResource FieldLabelStyle}">
                        <Run Text="Slit position:"/> <Run x:Name="SlitPositionValueText" Text="50%"/>
                    </TextBlock>
                    <Slider x:Name="SlitPositionSlider" Minimum="0" Maximum="100" Value="50"
                            ValueChanged="SlitPositionSlider_ValueChanged" Margin="0,2,0,4"/>
                    <TextBlock x:Name="SlitPositionDisabledHint" Foreground="{StaticResource CanonnTextMutedBrush}" FontSize="11"
                               Text="Not used in Rotational mode" Visibility="Collapsed" Margin="0,0,0,8"/>

                    <TextBlock Style="{StaticResource FieldLabelStyle}">
                        <Run Text="Slit width:"/> <Run x:Name="SlitWidthValueText" Text="2 px"/>
                    </TextBlock>
                    <Slider x:Name="SlitWidthSlider" Minimum="1" Maximum="50" Value="2"
                            ValueChanged="SlitWidthSlider_ValueChanged" Margin="0,2,0,12"/>

                    <CheckBox x:Name="AnimateWidthCheckBox" Content="Animate slit width over the render" Margin="0,0,0,8"
                              Checked="AnimateWidthCheckBox_CheckedChanged" Unchecked="AnimateWidthCheckBox_CheckedChanged"/>
                    <StackPanel x:Name="WidthAnimationPanel" Visibility="Collapsed" Margin="12,0,0,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}">
                            <Run Text="Ends at width:"/> <Run x:Name="SlitWidthEndValueText" Text="2 px"/>
                        </TextBlock>
                        <Slider x:Name="SlitWidthEndSlider" Minimum="1" Maximum="50" Value="2"
                                ValueChanged="SlitWidthEndSlider_ValueChanged" Margin="0,2,0,8"/>
                        <TextBlock Text="Width easing" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="WidthEasingCombo">
                            <ComboBoxItem Content="Linear" Tag="Linear" IsSelected="True"/>
                            <ComboBoxItem Content="Ease In" Tag="EaseIn"/>
                            <ComboBoxItem Content="Ease Out" Tag="EaseOut"/>
                            <ComboBoxItem Content="Ease In-Out" Tag="EaseInOut"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Motion -->
            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource GridCardStyle}">
                <StackPanel>
                    <TextBlock Text="Motion" Style="{StaticResource CardHeaderStyle}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <RadioButton x:Name="StaticModeRadio" Content="Static" GroupName="MotionMode" IsChecked="True"
                                     Style="{StaticResource ModeRadioStyle}" Checked="MotionModeRadio_Checked"/>
                        <RadioButton x:Name="SweepModeRadio" Content="Sweep" GroupName="MotionMode"
                                     Style="{StaticResource ModeRadioStyle}" Checked="MotionModeRadio_Checked"/>
                        <RadioButton x:Name="RotationalModeRadio" Content="Rotational" GroupName="MotionMode"
                                     Style="{StaticResource ModeRadioStyle}" Checked="MotionModeRadio_Checked"/>
                    </StackPanel>

                    <TextBlock x:Name="StaticModeHint" Foreground="{StaticResource CanonnTextMutedBrush}" TextWrapping="Wrap"
                               Text="Classic time-slice - the slit stays at the fixed position set under Geometry." Margin="0,0,0,4"/>

                    <StackPanel x:Name="SweepPanel" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource FieldLabelStyle}">
                            <Run Text="Sweep end position:"/> <Run x:Name="SweepEndValueText" Text="50%"/>
                        </TextBlock>
                        <Slider x:Name="SweepEndSlider" Minimum="0" Maximum="100" Value="50"
                                ValueChanged="SweepEndSlider_ValueChanged" Margin="0,2,0,8"/>
                        <TextBlock Text="Sweep easing" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="SweepEasingCombo">
                            <ComboBoxItem Content="Linear" Tag="Linear" IsSelected="True"/>
                            <ComboBoxItem Content="Ease In" Tag="EaseIn"/>
                            <ComboBoxItem Content="Ease Out" Tag="EaseOut"/>
                            <ComboBoxItem Content="Ease In-Out" Tag="EaseInOut"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel x:Name="RotationalPanel" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource FieldLabelStyle}">
                            <Run Text="Center X:"/> <Run x:Name="RotationCenterXValueText" Text="50%"/>
                        </TextBlock>
                        <Slider x:Name="RotationCenterXSlider" Minimum="0" Maximum="100" Value="50"
                                ValueChanged="RotationCenterXSlider_ValueChanged" Margin="0,2,0,8"/>
                        <TextBlock Style="{StaticResource FieldLabelStyle}">
                            <Run Text="Center Y:"/> <Run x:Name="RotationCenterYValueText" Text="50%"/>
                        </TextBlock>
                        <Slider x:Name="RotationCenterYSlider" Minimum="0" Maximum="100" Value="50"
                                ValueChanged="RotationCenterYSlider_ValueChanged" Margin="0,2,0,8"/>
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   ToolTip="Percentage of half the frame's shorter dimension, not a literal on-screen percentage - 100% keeps the orbit just inside the frame edge.">
                            <Run Text="Radius:"/> <Run x:Name="RotationRadiusValueText" Text="50%"/>
                        </TextBlock>
                        <Slider x:Name="RotationRadiusSlider" Minimum="1" Maximum="100" Value="50"
                                ValueChanged="RotationRadiusSlider_ValueChanged" Margin="0,2,0,8"/>
                        <TextBlock Style="{StaticResource FieldLabelStyle}">
                            <Run Text="Revolutions:"/> <Run x:Name="RotationRevolutionsValueText" Text="1.0"/>
                        </TextBlock>
                        <Slider x:Name="RotationRevolutionsSlider" Minimum="0.1" Maximum="10" Value="1.0"
                                ValueChanged="RotationRevolutionsSlider_ValueChanged" Margin="0,2,0,8"/>
                        <TextBlock Text="Direction" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="RotationDirectionCombo" SelectionChanged="RotationDirectionCombo_SelectionChanged">
                            <ComboBoxItem Content="Clockwise" Tag="Clockwise" IsSelected="True"/>
                            <ComboBoxItem Content="Counter-Clockwise" Tag="CounterClockwise"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Sampling -->
            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource GridCardStyle}">
                <StackPanel>
                    <TextBlock Text="Sampling" Style="{StaticResource CardHeaderStyle}"/>

                    <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4"
                               ToolTip="Which sampled frames end up at which position in the output, independent of where on-screen each sample was taken from."
                               Text="Sampling order"/>
                    <ComboBox x:Name="SamplingOrderCombo" SelectionChanged="SamplingOrderCombo_SelectionChanged" Margin="0,0,0,10">
                        <ComboBoxItem Content="Forward" Tag="Forward" IsSelected="True"/>
                        <ComboBoxItem Content="Reverse" Tag="Reverse"/>
                        <ComboBoxItem Content="Ping-Pong" Tag="PingPong" ToolTip="Plays forward then back, mirrored around the midpoint."/>
                        <ComboBoxItem Content="Random" Tag="Random" ToolTip="Shuffled (deterministically, via the random seed below)."/>
                    </ComboBox>
                    <StackPanel x:Name="RandomSeedPanel" Visibility="Collapsed" Margin="0,0,0,10">
                        <TextBlock Text="Random seed" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4"/>
                        <TextBox x:Name="RandomSeedTextBox" Text="0" Width="100" HorizontalAlignment="Left"
                                 TextChanged="ValidatedTextBox_TextChanged"/>
                    </StackPanel>

                    <TextBlock Style="{StaticResource FieldLabelStyle}">
                        <Run Text="Frame sampling interval:"/> <Run x:Name="FrameIntervalValueText" Text="every frame"/>
                    </TextBlock>
                    <Slider x:Name="FrameIntervalSlider" Minimum="1" Maximum="10" Value="1"
                            ValueChanged="FrameIntervalSlider_ValueChanged" Margin="0,2,0,12"/>

                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Trim range"/>
                    <Grid x:Name="TrimRangeTrack" Height="8" Margin="0,4,0,10" SizeChanged="TrimRangeTrack_SizeChanged">
                        <Border Background="{StaticResource CanonnSurfaceBrush}" CornerRadius="4"/>
                        <Border x:Name="TrimRangeFill" Background="{StaticResource CanonnAccentBrush}" CornerRadius="4"
                                HorizontalAlignment="Left" Height="8"/>
                    </Grid>

                    <TextBlock Style="{StaticResource FieldLabelStyle}">
                        <Run Text="In point:"/> <Run x:Name="InPointValueText" Text="0%"/>
                    </TextBlock>
                    <Slider x:Name="InPointSlider" Minimum="0" Maximum="99" Value="0"
                            ValueChanged="InPointSlider_ValueChanged" Margin="0,2,0,8"/>
                    <TextBlock Style="{StaticResource FieldLabelStyle}">
                        <Run Text="Out point:"/> <Run x:Name="OutPointValueText" Text="100%"/>
                    </TextBlock>
                    <Slider x:Name="OutPointSlider" Minimum="1" Maximum="100" Value="100"
                            ValueChanged="OutPointSlider_ValueChanged" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Compositing -->
            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource GridCardStyle}">
                <StackPanel>
                    <TextBlock Text="Compositing" Style="{StaticResource CardHeaderStyle}"/>

                    <TextBlock Style="{StaticResource FieldLabelStyle}">
                        <Run Text="Scan speed:"/> <Run x:Name="ScanSpeedValueText" Text="2 px/frame"/>
                    </TextBlock>
                    <Slider x:Name="ScanSpeedSlider" Minimum="1" Maximum="20" Value="2"
                            ValueChanged="ScanSpeedSlider_ValueChanged" Margin="0,2,0,12"/>

                    <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4"
                               ToolTip="Only visible when Scan speed is smaller than Slit width, so consecutive slits overlap. With no overlap (speed &#8805; width), this has no effect."
                               Text="Blend mode (overlapping slits only)"/>
                    <ComboBox x:Name="BlendModeCombo">
                        <ComboBoxItem Content="Normal" Tag="Normal" IsSelected="True" ToolTip="Later slits overwrite earlier ones in the overlap region."/>
                        <ComboBoxItem Content="Lighten" Tag="Lighten" ToolTip="Per-pixel brightest-of-the-overlap wins."/>
                        <ComboBoxItem Content="Average" Tag="Average" ToolTip="Per-pixel mean of every slit that covers that column."/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Output -->
            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource GridCardStyle}">
                <StackPanel>
                    <TextBlock Text="Output" Style="{StaticResource CardHeaderStyle}"/>

                    <CheckBox x:Name="CustomOutputSizeCheckBox" Content="Set output size independent of source" Margin="0,0,0,10"
                              Checked="CustomOutputSizeCheckBox_CheckedChanged" Unchecked="CustomOutputSizeCheckBox_CheckedChanged"/>
                    <StackPanel x:Name="OutputSizePanel" Visibility="Collapsed" Margin="12,0,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Width (px)" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="OutputWidthTextBox" Text="1920" Width="100" HorizontalAlignment="Left"
                                         TextChanged="ValidatedTextBox_TextChanged"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Height (px)" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="OutputHeightTextBox" Text="1080" Width="100" HorizontalAlignment="Left"
                                         TextChanged="ValidatedTextBox_TextChanged"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Interpolation" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="InterpolationCombo">
                            <ComboBoxItem Content="Nearest (blocky)" Tag="Nearest"/>
                            <ComboBoxItem Content="Linear" Tag="Linear"/>
                            <ComboBoxItem Content="Cubic (smooth)" Tag="Cubic" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

        </Grid>
    </StackPanel>
</UserControl>
