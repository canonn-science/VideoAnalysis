<Window x:Class="VideoAnalysis.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:converters="clr-namespace:VideoAnalysis.App.Converters"
        xmlns:views="clr-namespace:VideoAnalysis.App.Views"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="/Assets/canonn.ico"
        Title="Video Analysis Lab" Height="780" Width="1150"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">
    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header, styled after signals.canonn.tech's title bar -->
        <Border Grid.Row="0" Background="{StaticResource CanonnSurface3Brush}" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Video Analysis Lab" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource CanonnTextBrightBrush}"/>
                    <TextBlock Text="A suite of video analysis tools for Elite Dangerous citizen science"
                               FontSize="12" Foreground="{StaticResource CanonnTextMutedBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CommanderName}" FontWeight="SemiBold" FontSize="18"
                               Margin="0,0,12,0" VerticalAlignment="Center"
                               ToolTip="Set in the Configuration tab"
                               Foreground="{StaticResource CanonnTextBrightBrush}"/>
                    <Image Source="/Assets/canonn_logo.png" Height="64" Stretch="Uniform"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80*"/>
            </Grid.ColumnDefinitions>

            <views:VideoLibraryPanel Grid.Column="0" DataContext="{Binding VideoLibrary}"/>
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource CanonnBorderBrush}"/>

        <TabControl x:Name="RootTabControl" Grid.Column="2">
            <TabItem Header="Ring Rotation">
                <TabControl Margin="0,8,0,0">
                    <TabItem Header="System">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="Black" BorderBrush="{StaticResource CanonnBorderBrush}" BorderThickness="1"
                                        Height="160">
                                    <Image x:Name="RingRotationPreviewImage" Stretch="Uniform"/>
                                </Border>

                                <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Top">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"
                                               Foreground="{StaticResource CanonnTextBrightBrush}"
                                               Text="{Binding ActiveLibraryVideo.FileName, StringFormat='Selected video: {0}', FallbackValue='Select a video from the library on the left to get started.'}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Search row -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:AutoSuggestBox x:Name="SystemSearchBox" Grid.Column="0"
                                                   FontSize="16"
                                                   PlaceholderText="Auto-filled from the selected video, or type a system name…"
                                                   Text="{Binding SystemQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   ItemsSource="{Binding Suggestions}"
                                                   DisplayMemberPath="Name"
                                                   TextMemberPath="Name"
                                                   TextChanged="SystemSearchBox_TextChanged"
                                                   QuerySubmitted="SystemSearchBox_QuerySubmitted"
                                                   SuggestionChosen="SystemSearchBox_SuggestionChosen"/>
                                <Button Grid.Column="1" Content="Submit" Margin="8,0,0,0" Padding="16,8"
                                        FontSize="16" Background="{StaticResource CanonnAccentBrush}"
                                        Foreground="White" Click="SubmitButton_Click"/>
                            </Grid>

                            <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="#FF6B6B" Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                            <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="4" Margin="0,8,0,0"
                                         Foreground="{StaticResource CanonnAccentBrush}"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

                            <TextBlock Grid.Row="4" Margin="0,12,0,4" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource CanonnAccentBrush}"
                                       Text="{Binding ResolvedSystemName, StringFormat='Rings and belts in {0}'}"
                                       Visibility="{Binding ResolvedSystemName, Converter={StaticResource StringToVisibility}}"/>

                            <StackPanel Grid.Row="5" Margin="0,4,0,0">
                                <TextBlock Text="Body (optional - narrows the ring/belt choices)" FontWeight="SemiBold" Margin="0,0,0,4"
                                           Foreground="{StaticResource CanonnTextBrightBrush}"/>
                                <ComboBox MaxWidth="420" HorizontalAlignment="Left"
                                          ItemsSource="{Binding BodyNames}"
                                          SelectedItem="{Binding SelectedBodyName, Mode=TwoWay}"/>

                                <TextBlock Text="Ring / Belt" FontWeight="SemiBold" Margin="0,12,0,4"
                                           Foreground="{StaticResource CanonnTextBrightBrush}"/>
                                <ComboBox MaxWidth="420" HorizontalAlignment="Left"
                                          ItemsSource="{Binding RingChoices}" DisplayMemberPath="Display"
                                          SelectedItem="{Binding SelectedRing, Mode=TwoWay}"/>
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontSize="12"
                                           Foreground="{StaticResource CanonnTextMutedBrush}"
                                           Text="{Binding SelectedRing.DetailsSummary}"
                                           Visibility="{Binding HasSelectedRing, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>

                            <Button Grid.Row="6" Content="Analyze Video" Padding="24,8" Margin="0,12,0,0"
                                    HorizontalAlignment="Left" FontSize="16"
                                    Background="{StaticResource CanonnAccentBrush}" Foreground="White"
                                    IsEnabled="{Binding CanAnalyzeRing}"
                                    Click="RingRotationAnalyzeButton_Click"/>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Measurement History" DataContext="{Binding Measurements}">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="12,6" Margin="0,0,8,0"/>
                                <Button Content="Show File on Disk" Command="{Binding ShowOnDiskCommand}" Padding="12,6"
                                        Background="{StaticResource CanonnAccentBrush}" Foreground="White"/>
                            </StackPanel>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding Records}" AutoGenerateColumns="False"
                                      IsReadOnly="True" CanUserAddRows="False"
                                      SelectionUnit="CellOrRowHeader" SelectionMode="Extended" HeadersVisibility="All"
                                      Background="{StaticResource CanonnSurface2Brush}"
                                      RowBackground="{StaticResource CanonnSurfaceBrush}"
                                      AlternatingRowBackground="{StaticResource CanonnSurface2Brush}"
                                      BorderBrush="{StaticResource CanonnBorderBrush}" BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Recorded" Binding="{Binding TimestampDisplay}" Width="Auto"/>
                                    <DataGridTextColumn Header="System" Binding="{Binding SystemName}" Width="Auto"/>
                                    <DataGridTextColumn Header="Ring / Belt Name" Binding="{Binding RingName}" Width="Auto"/>
                                    <DataGridTextColumn Header="Inner Radius km" Binding="{Binding InnerRadiusDisplay}" Width="Auto"/>
                                    <DataGridTextColumn Header="Outer Radius km" Binding="{Binding OuterRadiusDisplay}" Width="Auto"/>
                                    <DataGridTextColumn Header="Width km" Binding="{Binding WidthDisplay}" Width="Auto"/>
                                    <DataGridTextColumn Header="Estimated Rotation s" Binding="{Binding EstimatedRotationDisplay}" Width="Auto"/>
                                    <DataGridTextColumn Header="Observed Rotation s" Binding="{Binding ObservedRotationDisplay}" Width="Auto"/>
                                    <DataGridTextColumn Header="Video File" Binding="{Binding VideoFilename}" Width="*"/>
                                    <DataGridTemplateColumn Header="Canonn" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Button Command="{Binding SendToCanonnCommand}"
                                                            IsEnabled="{Binding CanSend}"
                                                            Visibility="{Binding IsSubmitted, Converter={StaticResource InverseBoolToVisibility}}"
                                                            Padding="6,4" ToolTip="{Binding SendTooltip}">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE898;"
                                                                   Foreground="{StaticResource CanonnAccentBrush}"/>
                                                    </Button>
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE73E;"
                                                               Foreground="#4CAF50" FontSize="16"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               ToolTip="Already submitted to Canonn"
                                                               Visibility="{Binding IsSubmitted, Converter={StaticResource BoolToVisibility}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <TabItem Header="Station Rotation" DataContext="{Binding Stations}">
                <TabControl Margin="0,8,0,0">
                    <TabItem Header="System">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="Black" BorderBrush="{StaticResource CanonnBorderBrush}" BorderThickness="1"
                                        Height="160">
                                    <Image x:Name="StationPreviewImage" Stretch="Uniform"/>
                                </Border>

                                <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Top">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"
                                               Foreground="{StaticResource CanonnTextBrightBrush}"
                                               Text="{Binding VideoFileName, StringFormat='Selected video: {0}', FallbackValue='Select a video from the library on the left to get started.'}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:AutoSuggestBox x:Name="StationSystemSearchBox" Grid.Column="0"
                                                   FontSize="16"
                                                   PlaceholderText="Auto-filled from the selected video, or type a system name…"
                                                   Text="{Binding SystemQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   ItemsSource="{Binding Suggestions}"
                                                   DisplayMemberPath="Name"
                                                   TextMemberPath="Name"
                                                   TextChanged="StationSystemSearchBox_TextChanged"
                                                   QuerySubmitted="StationSystemSearchBox_QuerySubmitted"
                                                   SuggestionChosen="StationSystemSearchBox_SuggestionChosen"/>
                                <Button Grid.Column="1" Content="Submit" Margin="8,0,0,0" Padding="16,8"
                                        FontSize="16" Background="{StaticResource CanonnAccentBrush}"
                                        Foreground="White" Click="StationSubmitButton_Click"/>
                            </Grid>

                            <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="#FF6B6B" Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                            <ProgressBar Grid.Row="3" IsIndeterminate="True" Height="4" Margin="0,8,0,0"
                                         Foreground="{StaticResource CanonnAccentBrush}"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

                            <TextBlock Grid.Row="4" Margin="0,12,0,4" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource CanonnAccentBrush}"
                                       Text="{Binding ResolvedSystemName, StringFormat='Stations, installations, and Guardian Beacons in {0}'}"
                                       Visibility="{Binding ResolvedSystemName, Converter={StaticResource StringToVisibility}}"/>

                            <StackPanel Grid.Row="5" Margin="0,4,0,0">
                                <TextBlock Text="Station" FontWeight="SemiBold" Margin="0,0,0,4"
                                           Foreground="{StaticResource CanonnTextBrightBrush}"/>
                                <ComboBox MaxWidth="420" HorizontalAlignment="Left"
                                          ItemsSource="{Binding Stations}" DisplayMemberPath="Display"
                                          SelectedItem="{Binding SelectedStation, Mode=TwoWay}"/>
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" FontSize="12"
                                           Foreground="{StaticResource CanonnTextMutedBrush}"
                                           Text="{Binding SelectedStation.DetailsSummary}"
                                           Visibility="{Binding HasSelectedStation, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>

                            <Button Grid.Row="6" Content="Analyze Video" Padding="24,8" Margin="0,12,0,0"
                                    HorizontalAlignment="Left" FontSize="16"
                                    Background="{StaticResource CanonnAccentBrush}" Foreground="White"
                                    IsEnabled="{Binding CanAnalyze}"
                                    Click="StationAnalyzeButton_Click"/>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Measurement History" DataContext="{Binding Measurements}">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="12,6" Margin="0,0,8,0"/>
                                <Button Content="Show File on Disk" Command="{Binding ShowOnDiskCommand}" Padding="12,6"
                                        Background="{StaticResource CanonnAccentBrush}" Foreground="White"/>
                            </StackPanel>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding Records}" AutoGenerateColumns="False"
                                      IsReadOnly="True" CanUserAddRows="False"
                                      SelectionUnit="CellOrRowHeader" SelectionMode="Extended" HeadersVisibility="All"
                                      Background="{StaticResource CanonnSurface2Brush}"
                                      RowBackground="{StaticResource CanonnSurfaceBrush}"
                                      AlternatingRowBackground="{StaticResource CanonnSurface2Brush}"
                                      BorderBrush="{StaticResource CanonnBorderBrush}" BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="System" Binding="{Binding SystemName}" Width="Auto"/>
                                    <DataGridTextColumn Header="Station Name" Binding="{Binding StationName}" Width="Auto"/>
                                    <DataGridTextColumn Header="Body" Binding="{Binding BodyName}" Width="Auto"/>
                                    <DataGridTextColumn Header="Body Radius" Binding="{Binding BodyRadiusDisplay}" Width="Auto"/>
                                    <DataGridTextColumn Header="Body Rotational Period" Binding="{Binding BodyRotationalPeriodDisplay}" Width="Auto"/>
                                    <DataGridTextColumn Header="Body Inclination" Binding="{Binding BodyInclinationDisplay}" Width="Auto"/>
                                    <DataGridTextColumn Header="Estimated Rotation (s)" Binding="{Binding EstimatedRotationDisplay}" Width="Auto"/>
                                    <DataGridTextColumn Header="Actual Rotation (s)" Binding="{Binding ObservedRotationDisplay}" Width="Auto"/>
                                    <DataGridTextColumn Header="Video File" Binding="{Binding VideoFilename}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <TabItem Header="Jet Cone Length" DataContext="{Binding JetCone}">
                <TabControl Margin="0,8,0,0">
                    <TabItem Header="Measure">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{StaticResource CanonnSurface2Brush}" BorderBrush="{StaticResource CanonnBorderBrush}"
                                        BorderThickness="1" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="How to film it" FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{StaticResource CanonnTextBrightBrush}" Margin="0,0,0,8"/>
                                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource CanonnTextBrush}" LineHeight="20"
                                                   Text="Fly out away from the neutron star parallel to the jets. Turn around and fly directly towards the jet, adjusting your approach to ensure that the end of a jet cone is the only part visible. Fly as direct as you can to the cone, keeping the speed low enough that you can see the distance counter change 1 hundredth of a light second at a time. Keep speed constant. Stop recording when the Frameshift Turbulence begins."/>
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Row="1" Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="Black" BorderBrush="{StaticResource CanonnBorderBrush}" BorderThickness="1"
                                            Height="220">
                                        <Image x:Name="JetConePreviewImage" Stretch="Uniform"/>
                                    </Border>

                                    <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Top">
                                        <TextBlock FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"
                                                   Foreground="{StaticResource CanonnTextBrightBrush}"
                                                   Text="{Binding VideoFileName, StringFormat='Selected video: {0}', FallbackValue='Select a video from the library on the left to get started.'}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="#FF6B6B" Margin="0,12,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                                <StackPanel Grid.Row="3" Margin="0,16,0,0">
                                    <TextBlock Text="Target" FontWeight="SemiBold" Margin="0,0,0,4"
                                               Foreground="{StaticResource CanonnTextBrightBrush}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:AutoSuggestBox x:Name="JetConeSystemSearchBox" Grid.Column="0"
                                                           PlaceholderText="Auto-filled from the selected video, or type a system name…"
                                                           Text="{Binding SystemQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           ItemsSource="{Binding Suggestions}"
                                                           DisplayMemberPath="Name"
                                                           TextMemberPath="Name"
                                                           TextChanged="JetConeSystemSearchBox_TextChanged"
                                                           QuerySubmitted="JetConeSystemSearchBox_QuerySubmitted"
                                                           SuggestionChosen="JetConeSystemSearchBox_SuggestionChosen"/>
                                        <Button Grid.Column="1" Content="Look Up" Margin="8,0,0,0" Padding="12,6"
                                                Click="JetConeSubmitButton_Click"/>
                                    </Grid>

                                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,8,0,0"
                                                 Foreground="{StaticResource CanonnAccentBrush}"
                                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

                                    <TextBlock Margin="0,8,0,4" FontSize="12" Foreground="{StaticResource CanonnTextMutedBrush}"
                                               Text="{Binding ResolvedSystemName, StringFormat='Neutron stars and white dwarfs in {0}:'}"
                                               Visibility="{Binding ResolvedSystemName, Converter={StaticResource StringToVisibility}}"/>
                                    <ComboBox MaxWidth="420" HorizontalAlignment="Left"
                                              ItemsSource="{Binding Targets}" DisplayMemberPath="Display"
                                              SelectedItem="{Binding SelectedTarget, Mode=TwoWay}"/>
                                </StackPanel>

                                <Button Grid.Row="4" Content="Analyze Video" Padding="24,8" Margin="0,16,0,0"
                                        HorizontalAlignment="Left" FontSize="16"
                                        Background="{StaticResource CanonnAccentBrush}" Foreground="White"
                                        IsEnabled="{Binding CanAnalyze}"
                                        Click="JetConeAnalyzeButton_Click"/>

                                <Grid Grid.Row="5" Margin="0,20,0,0" Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Confirm the distance reading" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource CanonnAccentBrush}"/>
                                    <TextBlock Grid.Row="1" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="13"
                                               Foreground="{StaticResource CanonnTextMutedBrush}"
                                               Text="Frame captured at the moment the FSD warning overlay appeared. Check the value against the reticle readout below and correct it if needed."/>

                                    <Border Grid.Row="2" Background="Black" BorderBrush="{StaticResource CanonnBorderBrush}" BorderThickness="1"
                                            Margin="0,12,0,0" Padding="4" HorizontalAlignment="Left">
                                        <Image x:Name="JetConeReticleImage" Stretch="Uniform" MaxHeight="360" MaxWidth="640"/>
                                    </Border>

                                    <Border Grid.Row="3" Background="Black" BorderBrush="{StaticResource CanonnBorderBrush}" BorderThickness="1"
                                            Margin="0,8,0,0" Padding="4" HorizontalAlignment="Left">
                                        <Image x:Name="JetConeBottomLeftImage" Stretch="Uniform" MaxHeight="140" MaxWidth="640"/>
                                    </Border>

                                    <Grid Grid.Row="4" Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="Distance (Ls):" VerticalAlignment="Center" FontWeight="SemiBold"
                                                   Foreground="{StaticResource CanonnTextBrightBrush}" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBox x:Name="JetConeDistanceTextBox" Width="140" HorizontalAlignment="Left" FontSize="16"/>
                                            <TextBlock FontSize="11" Margin="0,4,0,0"
                                                       Foreground="{StaticResource CanonnTextMutedBrush}"
                                                       Text="{Binding DistanceSourceLabel}"/>
                                        </StackPanel>

                                        <Button x:Name="JetConeSendToCanonnButton" Grid.Column="2" Content="Send to Canonn"
                                                Padding="16,8" Margin="0,0,8,0"
                                                IsEnabled="{Binding CanSubmitReviewToCanonn}"
                                                Click="JetConeSendToCanonnButton_Click"/>
                                        <Button Grid.Column="3" Content="Discard" Padding="16,8" Margin="0,0,8,0"
                                                Click="JetConeDiscardReviewButton_Click"/>
                                        <Button Grid.Column="4" Content="Save Measurement" Padding="24,8"
                                                Background="{StaticResource CanonnAccentBrush}" Foreground="White"
                                                Click="JetConeSaveMeasurementButton_Click"/>
                                    </Grid>

                                    <TextBlock Grid.Row="5" Text="{Binding CanonnSubmitError}" Foreground="#FF6B6B" Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding CanonnSubmitError, Converter={StaticResource StringToVisibility}}"/>
                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Measurement History" DataContext="{Binding Measurements}">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="12,6" Margin="0,0,8,0"/>
                                <Button Content="Show File on Disk" Command="{Binding ShowOnDiskCommand}" Padding="12,6" Margin="0,0,8,0"
                                        Background="{StaticResource CanonnAccentBrush}" Foreground="White"/>
                                <Button Content="Send Selected to Canonn" Command="{Binding SendSelectedToCanonnCommand}" Padding="12,6"/>
                            </StackPanel>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding Records}" AutoGenerateColumns="False"
                                      IsReadOnly="True" CanUserAddRows="False"
                                      SelectionUnit="CellOrRowHeader" SelectionMode="Extended" HeadersVisibility="All"
                                      Background="{StaticResource CanonnSurface2Brush}"
                                      RowBackground="{StaticResource CanonnSurfaceBrush}"
                                      AlternatingRowBackground="{StaticResource CanonnSurface2Brush}"
                                      BorderBrush="{StaticResource CanonnBorderBrush}" BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          IsEnabled="{Binding CanSend}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="System" Binding="{Binding SystemName}" Width="Auto"/>
                                    <DataGridTextColumn Header="Body" Binding="{Binding BodyName}" Width="Auto"/>
                                    <DataGridTextColumn Header="Distance" Binding="{Binding DistanceDisplay}" Width="Auto"/>
                                    <DataGridTextColumn Header="Rotational Period" Binding="{Binding RotationalPeriodDisplay}" Width="Auto"/>
                                    <DataGridTextColumn Header="Spectral Class" Binding="{Binding SpectralClassDisplay}" Width="*"/>
                                    <DataGridTemplateColumn Header="Canonn" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Button Command="{Binding SendToCanonnCommand}"
                                                            IsEnabled="{Binding CanSend}"
                                                            Visibility="{Binding IsSubmitted, Converter={StaticResource InverseBoolToVisibility}}"
                                                            Padding="6,4" ToolTip="{Binding SendTooltip}">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE898;"
                                                                   Foreground="{StaticResource CanonnAccentBrush}"/>
                                                    </Button>
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE73E;"
                                                               Foreground="#4CAF50" FontSize="16"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               ToolTip="Already submitted to Canonn"
                                                               Visibility="{Binding IsSubmitted, Converter={StaticResource BoolToVisibility}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <TabItem Header="Long Exposure" DataContext="{Binding LongExposure}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontSize="14" Foreground="{StaticResource CanonnTextBrightBrush}"
                               Text="{Binding VideoFileName, StringFormat='Selected video: {0}', FallbackValue='Select a video from the library on the left to get started.'}"/>

                    <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="#FF6B6B" Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                    <Border Grid.Row="2" Background="{StaticResource CanonnSurface2Brush}" BorderBrush="{StaticResource CanonnBorderBrush}"
                            BorderThickness="1" Padding="14" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource CanonnTextBrightBrush}" Margin="0,0,0,4"
                                       Text="Modes to generate"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,10"
                                       Foreground="{StaticResource CanonnTextMutedBrush}"
                                       Text="Uncheck any you don't need - skipped modes aren't computed at all, so fewer checked modes means faster generation."/>

                            <CheckBox Margin="0,0,0,10" IsChecked="{Binding IncludeAverage, Mode=TwoWay}">
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource CanonnTextBrush}">
                                    <Run FontWeight="SemiBold" Foreground="{StaticResource CanonnTextBrightBrush}" Text="Average"/><Run Text=" - smooths out anything that moves, leaving only static objects sharp: the classic long-exposure look."/>
                                </TextBlock>
                            </CheckBox>
                            <CheckBox Margin="0,0,0,10" IsChecked="{Binding IncludeMaximum, Mode=TwoWay}">
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource CanonnTextBrush}">
                                    <Run FontWeight="SemiBold" Foreground="{StaticResource CanonnTextBrightBrush}" Text="Maximum"/><Run Text=" - keeps the brightest value seen at each pixel across the whole clip: good for star trails and bright motion streaks."/>
                                </TextBlock>
                            </CheckBox>
                            <CheckBox Margin="0,0,0,10" IsChecked="{Binding IncludeMinimum, Mode=TwoWay}">
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource CanonnTextBrush}">
                                    <Run FontWeight="SemiBold" Foreground="{StaticResource CanonnTextBrightBrush}" Text="Minimum"/><Run Text=" - keeps the darkest value seen at each pixel: highlights whatever consistently stayed dark, e.g. a transiting body."/>
                                </TextBlock>
                            </CheckBox>
                            <CheckBox Margin="0,0,0,10" IsChecked="{Binding IncludeMaxMinusMin, Mode=TwoWay}">
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource CanonnTextBrush}">
                                    <Run FontWeight="SemiBold" Foreground="{StaticResource CanonnTextBrightBrush}" Text="Max Minus Min"/><Run Text=" - the difference between brightest and darkest at each pixel: isolates whatever changed from what stayed static."/>
                                </TextBlock>
                            </CheckBox>
                            <CheckBox Margin="0,0,0,10" IsChecked="{Binding IncludeMotionVariance, Mode=TwoWay}">
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource CanonnTextBrush}">
                                    <Run FontWeight="SemiBold" Foreground="{StaticResource CanonnTextBrightBrush}" Text="Motion Variance"/><Run Text=" - a heatmap of how much each pixel fluctuated over time: moving regions light up, static background goes black."/>
                                </TextBlock>
                            </CheckBox>
                            <CheckBox IsChecked="{Binding IncludeMotionBlur, Mode=TwoWay}">
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource CanonnTextBrush}">
                                    <Run FontWeight="SemiBold" Foreground="{StaticResource CanonnTextBrightBrush}" Text="Motion Blur"/><Run Text=" - a fading trail effect where recent motion dominates but older bright spots fade out, rather than persisting forever like Maximum's trails."/>
                                </TextBlock>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="3" Margin="0,16,0,0" MaxWidth="420" HorizontalAlignment="Left"
                                IsEnabled="{Binding IncludeMotionBlur}">
                        <TextBlock Foreground="{StaticResource CanonnTextBrightBrush}" FontWeight="SemiBold">
                            <Run Text="Motion Blur trail length:"/> <Run x:Name="MotionBlurAlphaValueText" Text="0.15"/>
                        </TextBlock>
                        <Slider x:Name="MotionBlurAlphaSlider" Minimum="0.02" Maximum="0.6" Value="0.15"
                                SmallChange="0.01" LargeChange="0.05"
                                ValueChanged="MotionBlurAlphaSlider_ValueChanged" Margin="0,4,0,0"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource CanonnTextMutedBrush}" Margin="0,4,0,0"
                                   Text="Lower = longer, fainter trails. Higher = shorter, sharper trails. Only affects the Motion Blur variant."/>
                    </StackPanel>

                    <Button Grid.Row="4" Content="Generate Long Exposure" Padding="24,8" Margin="0,16,0,0"
                            HorizontalAlignment="Left" FontSize="16"
                            Background="{StaticResource CanonnAccentBrush}" Foreground="White"
                            Click="LongExposureGenerateButton_Click"/>

                    <Grid Grid.Row="5" Margin="0,16,0,0" Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Select a variation to preview, then save it or save all of them." FontSize="14"
                                   FontWeight="SemiBold" Foreground="{StaticResource CanonnAccentBrush}" Margin="0,0,0,12"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="Black" BorderBrush="{StaticResource CanonnBorderBrush}" BorderThickness="1">
                                <Image x:Name="LongExposurePreviewImage" Stretch="Uniform"/>
                            </Border>

                            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                                          Background="{StaticResource CanonnBorderBrush}"/>

                            <ListBox x:Name="LongExposureVariantList" Grid.Column="2" SelectionMode="Single"
                                     Background="Transparent" BorderThickness="0" Margin="8,0,0,0"
                                     SelectionChanged="LongExposureVariantList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Black" BorderBrush="{StaticResource CanonnBorderBrush}" BorderThickness="1"
                                                Margin="0,0,0,8" Padding="4">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding Thumbnail}" Stretch="Uniform" Width="90" Height="60"/>
                                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" Margin="8,0,0,0"
                                                           Foreground="{StaticResource CanonnTextBrightBrush}" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button x:Name="LongExposureSaveSelectedButton" Content="Save Selected…" Padding="16,8" Margin="0,0,8,0"
                                    Click="LongExposureSaveSelectedButton_Click"/>
                            <Button Content="Save All…" Padding="16,8"
                                    Background="{StaticResource CanonnAccentBrush}" Foreground="White"
                                    Click="LongExposureSaveAllButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Slit Scan" DataContext="{Binding SlitScan}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" VerticalAlignment="Center" FontSize="14"
                               Foreground="{StaticResource CanonnTextBrightBrush}"
                               Text="{Binding VideoFileName, StringFormat='Selected video: {0}', FallbackValue='Select a video from the library on the left to get started.'}"/>

                    <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="#FF6B6B" Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                    <ScrollViewer Grid.Row="2" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <views:SlitScanControlPanel x:Name="SlitScanControls"/>
                    </ScrollViewer>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="Generate Slit Scan" Padding="24,8"
                                Background="{StaticResource CanonnAccentBrush}" Foreground="White"
                                Click="SlitScanGenerateButton_Click"/>
                        <Button Content="Reset Controls" Padding="16,6" Margin="24,0,0,0"
                                Background="Transparent" BorderBrush="{StaticResource CanonnBorderBrush}"
                                Foreground="{StaticResource CanonnTextMutedBrush}"
                                Click="SlitScanResetButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem x:Name="ConfigurationTabItem" Header="Configuration">
                <Grid Margin="12">
                    <StackPanel MaxWidth="640" HorizontalAlignment="Left">
                        <TextBlock Text="Configuration" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource CanonnTextBrightBrush}"/>
                        <TextBlock Text="Manage application settings and account preferences." FontSize="12"
                                   Foreground="{StaticResource CanonnTextMutedBrush}" Margin="0,2,0,0"/>

                        <Border Background="{StaticResource CanonnSurface2Brush}" BorderBrush="{StaticResource CanonnBorderBrush}"
                                BorderThickness="1" Padding="14" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Elite Dangerous" FontWeight="SemiBold" FontSize="14"
                                           Foreground="{StaticResource CanonnTextBrightBrush}"/>

                                <CheckBox Content="Monitor Elite Dangerous Journals" Margin="0,12,0,0"
                                          IsChecked="{Binding MonitorJournals, Mode=TwoWay}"/>
                                <TextBlock Margin="24,4,0,0" TextWrapping="Wrap" FontSize="12"
                                           Foreground="{StaticResource CanonnTextMutedBrush}"
                                           Text="Watches your journal folder to detect your commander name and current system location automatically, and keeps them up to date as you play."/>

                                <CheckBox Content="Override username from game journals" Margin="0,14,0,0"
                                          IsChecked="{Binding OverrideUsername, Mode=TwoWay}"
                                          IsEnabled="{Binding MonitorJournals}"/>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Commander Name:" VerticalAlignment="Center"
                                               Foreground="{StaticResource CanonnTextBrush}" Margin="0,0,8,0"/>
<TextBox Grid.Column="1" MinWidth="240" HorizontalAlignment="Left"
         Text="{Binding CommanderName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}">
    <TextBox.Style>
        <Style TargetType="TextBox">
            <Setter Property="IsEnabled" Value="True"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding MonitorJournals}" Value="True"/>
                        <Condition Binding="{Binding OverrideUsername}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="IsEnabled" Value="False"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </TextBox.Style>
</TextBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource CanonnSurface2Brush}" BorderBrush="{StaticResource CanonnBorderBrush}"
                                BorderThickness="1" Padding="14" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Video Library" FontWeight="SemiBold" FontSize="14"
                                           Foreground="{StaticResource CanonnTextBrightBrush}"/>

                                <CheckBox Content="Organize renamed videos into a folder named after the system" Margin="0,12,0,0"
                                          IsChecked="{Binding OrganizeRenamedVideosBySystem, Mode=TwoWay}"/>
                                <TextBlock Margin="24,4,0,0" TextWrapping="Wrap" FontSize="12"
                                           Foreground="{StaticResource CanonnTextMutedBrush}"
                                           Text="When accepting a suggested rename from the &quot;Add to Video Library&quot; dialog, moves the file into a same-folder subdirectory named after its system instead of leaving it alongside the original."/>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource CanonnSurface2Brush}" BorderBrush="{StaticResource CanonnBorderBrush}"
                                BorderThickness="1" Padding="14" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Claude" FontWeight="SemiBold" FontSize="14"
                                           Foreground="{StaticResource CanonnTextBrightBrush}"/>
                                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" FontSize="12"
                                           Foreground="{StaticResource CanonnTextMutedBrush}"
                                           Text="Optional. Used only as a fallback for Jet Cone Length's distance reading when local text recognition can't read a frame reliably. Never required for anything else in the app."/>
                                <TextBlock x:Name="ClaudeApiKeyStatusText" Margin="0,10,0,0"
                                           Foreground="{StaticResource CanonnTextBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Content="Add / Replace API Key" Padding="10,4" Margin="0,0,8,0"
                                            Click="AddReplaceClaudeApiKeyButton_Click"/>
                                    <Button Content="Delete API Key" Padding="10,4" Click="DeleteClaudeApiKeyButton_Click"
                                            Visibility="{Binding HasClaudeApiKey, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="About">
                <Grid Margin="12">
                    <StackPanel MaxWidth="640" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/canonn_logo.png" Height="56" Stretch="Uniform" Margin="0,0,16,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Video Analysis Lab" FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource CanonnTextBrightBrush}"/>
                                <TextBlock x:Name="VersionText" FontSize="13"
                                           Foreground="{StaticResource CanonnTextMutedBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Margin="0,20,0,0" TextWrapping="Wrap" LineHeight="20"
                                   Foreground="{StaticResource CanonnTextBrush}"
                                   Text="Video Analysis Lab measures how fast a planetary ring or asteroid belt is rotating in Elite Dangerous. It estimates the rotation period from orbital mechanics, tells you how long a video to record to confirm it, and then measures the actual period from that recording - producing a logged data point for Canonn's citizen-science ring-rotation project."/>

                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <TextBlock Text="Project home: " FontWeight="SemiBold"
                                       Foreground="{StaticResource CanonnTextBrightBrush}"/>
                            <TextBlock>
                                <Hyperlink NavigateUri="https://canonn.science/" RequestNavigate="Hyperlink_RequestNavigate">canonn.science</Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Source &amp; releases: " FontWeight="SemiBold"
                                       Foreground="{StaticResource CanonnTextBrightBrush}"/>
                            <TextBlock>
                                <Hyperlink NavigateUri="https://github.com/canonn-science/VideoAnalysis" RequestNavigate="Hyperlink_RequestNavigate">github.com/canonn-science/VideoAnalysis</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
        </Grid>
    </Grid>
</Window>
