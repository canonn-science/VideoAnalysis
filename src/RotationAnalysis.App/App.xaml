<Application x:Class="RotationAnalysis.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:local="clr-namespace:RotationAnalysis.App"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources />
                <ui:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <!-- Canonn Signals palette (signals.canonn.tech), matched from its compiled stylesheet -->
            <Color x:Key="CanonnAccentColor">#FF9900</Color>
            <Color x:Key="CanonnWindowBackgroundColor">#303030</Color>
            <Color x:Key="CanonnSurfaceColor">#393939</Color>
            <Color x:Key="CanonnSurface2Color">#2A2A2A</Color>
            <Color x:Key="CanonnSurface3Color">#1C1C1C</Color>
            <Color x:Key="CanonnSurfaceHoverColor">#555555</Color>
            <Color x:Key="CanonnTextColor">#E0E0E0</Color>
            <Color x:Key="CanonnTextBrightColor">#F2F2F2</Color>
            <Color x:Key="CanonnTextMutedColor">#888888</Color>
            <Color x:Key="CanonnBorderColor">#797979</Color>
            <Color x:Key="CanonnLinkColor">#FBD7B4</Color>

            <SolidColorBrush x:Key="CanonnAccentBrush" Color="{StaticResource CanonnAccentColor}"/>
            <SolidColorBrush x:Key="CanonnWindowBackgroundBrush" Color="{StaticResource CanonnWindowBackgroundColor}"/>
            <SolidColorBrush x:Key="CanonnSurfaceBrush" Color="{StaticResource CanonnSurfaceColor}"/>
            <SolidColorBrush x:Key="CanonnSurface2Brush" Color="{StaticResource CanonnSurface2Color}"/>
            <SolidColorBrush x:Key="CanonnSurface3Brush" Color="{StaticResource CanonnSurface3Color}"/>
            <SolidColorBrush x:Key="CanonnSurfaceHoverBrush" Color="{StaticResource CanonnSurfaceHoverColor}"/>
            <SolidColorBrush x:Key="CanonnTextBrush" Color="{StaticResource CanonnTextColor}"/>
            <SolidColorBrush x:Key="CanonnTextBrightBrush" Color="{StaticResource CanonnTextBrightColor}"/>
            <SolidColorBrush x:Key="CanonnTextMutedBrush" Color="{StaticResource CanonnTextMutedColor}"/>
            <SolidColorBrush x:Key="CanonnBorderBrush" Color="{StaticResource CanonnBorderColor}"/>
            <SolidColorBrush x:Key="CanonnLinkBrush" Color="{StaticResource CanonnLinkColor}"/>

            <FontFamily x:Key="CanonnFontFamily">Roboto, Segoe UI, sans-serif</FontFamily>

            <Style TargetType="Window">
                <Setter Property="Background" Value="{StaticResource CanonnWindowBackgroundBrush}"/>
                <Setter Property="FontFamily" Value="{StaticResource CanonnFontFamily}"/>
                <Setter Property="TextElement.Foreground" Value="{StaticResource CanonnTextBrush}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
