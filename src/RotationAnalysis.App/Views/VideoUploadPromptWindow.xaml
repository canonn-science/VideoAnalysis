<Window x:Class="RotationAnalysis.App.Views.VideoUploadPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="/Assets/canonn.ico"
        Title="Select Your Recording" Height="740" Width="820"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Record from the ring, facing the horizon" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource CanonnAccentBrush}"/>
            <TextBlock Text="Click the image below to browse for your video, or drag and drop a file onto it."
                       FontSize="13" Foreground="{StaticResource CanonnTextMutedBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" x:Name="DropTarget" BorderBrush="{StaticResource CanonnAccentBrush}" BorderThickness="2"
                Background="{StaticResource CanonnSurface3Brush}" Cursor="Hand"
                AllowDrop="True" Drop="DropTarget_Drop" DragEnter="DropTarget_DragEnter" DragLeave="DropTarget_DragLeave"
                MouseLeftButtonUp="DropTarget_Click">
            <Grid>
                <Image Source="/Assets/example_horizontal_shot.jpg" Stretch="Uniform" Margin="4"/>
                <Border x:Name="DragOverlay" Background="#802A6B2A" Visibility="Collapsed">
                    <TextBlock Text="Drop video to select" FontSize="24" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <TextBlock FontWeight="SemiBold" Foreground="{StaticResource CanonnTextBrightBrush}" Text="How to film it:" Margin="0,0,0,6"/>
            <TextBlock Foreground="{StaticResource CanonnTextBrush}" TextWrapping="Wrap" LineHeight="20">
                <Run Text="•  Park your ship on the ring surface and use free camera, facing directly away from the central body, toward the horizon."/>
                <LineBreak/>
                <Run Text="•  Keep the horizon roughly centered vertically in frame, as shown above - asteroids below, open starfield above."/>
                <LineBreak/>
                <Run Text="•  Do not zoom - use the default field of view."/>
                <LineBreak/>
                <Run Text="•  Record for at least a minute or two; longer recordings give a more confident result."/>
            </TextBlock>
        </StackPanel>

        <Button Grid.Row="3" Content="Cancel" HorizontalAlignment="Right" Margin="0,16,0,0" Padding="16,8"
                Click="CancelButton_Click"/>
    </Grid>
</Window>
