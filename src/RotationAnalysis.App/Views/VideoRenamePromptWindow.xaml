<Window x:Class="RotationAnalysis.App.Views.VideoRenamePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="/Assets/canonn.ico"
        Title="Rename Video?" Height="220" Width="460"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" FontSize="14" Foreground="{StaticResource CanonnTextBrightBrush}">
            <Run Text="This video's filename doesn't match its ring. Rename it to"/>
            <Run x:Name="SuggestedNameRun" FontWeight="Bold"/>
            <Run Text="?"/>
        </TextBlock>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Keep Current Name" Padding="16,8" Margin="0,0,8,0" Click="KeepButton_Click" IsCancel="True"/>
            <Button Content="Rename" Padding="24,8" Background="{StaticResource CanonnAccentBrush}" Foreground="White"
                    Click="RenameButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
